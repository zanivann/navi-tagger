{
  "productName": "Navi-Tagger",
  "version": "2.2.0",
  "identifier": "com.zanivann.navitagger",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
